generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- IDENTITY & CRM LAYER ---
model Contact {
  id           String   @id @default(uuid())
  name         String
  company      String
  email        String   @unique
  status       String
  qbCustomerId String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deals        Deal[]
}

model Deal {
  id          String   @id @default(uuid())
  title       String
  owner       String
  valueCents  BigInt   // ASC 606 Precision
  stage       String
  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id])
  createdAt   DateTime @default(now())
}

// --- PROCUREMENT & ERP LAYER (Acumatica/SAP/Concur) ---
model Vendor {
  id             String   @id @default(uuid())
  name           String
  externalId     String?  @unique // SAP/Acumatica ID
  category       String
  riskScore      Int      @default(0) // From Intelligence Hub
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime @default(now())
}

model PurchaseOrder {
  id           String   @id @default(uuid())
  poNumber     String   @unique
  vendorId     String
  vendor       Vendor   @relation(fields: [vendorId], references: [id])
  totalCents   BigInt
  status       String   // DRAFT, APPROVED, FULFILLED, VOID
  costCenterId String?
  externalSync Json?    // Metadata for Concur/SAP sync status
  createdAt    DateTime @default(now())
}

model CostCenter {
  id          String   @id @default(uuid())
  code        String   @unique // e.g., "DEVOPS-01"
  name        String
  budgetCents BigInt
  spentCents  BigInt   @default(0)
}

// --- INTELLIGENCE & AUDIT LAYER ---
model Activity {
  id        String   @id @default(uuid())
  text      String
  category  String   // PROCUREMENT, FINANCE, IDENTITY, SYSTEM
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model IntelligenceSnapshot {
  id            String   @id @default(uuid())
  scsScore      Int
  liquidityRatio Float
  burnRateCents BigInt
  timestamp     DateTime @default(now())
}

// --- FINANCE & GENERAL LEDGER (SAP 4HANA STYLE) ---

model ChartOfAccounts {
  code        String   @id // e.g. "5000", "1100"
  orgId      String
  name       String   // "Cost of Goods Sold", "Accounts Receivable"
  type       String   // "asset" | "liability" | "equity" | "revenue" | "expense"
  parentCode String?
  isActive   Boolean  @default(true)
  
  @@index([orgId, code])
}

model GeneralLedger {
  id            String   @id @default(cuid())
  orgId         String
  entryDate    DateTime
  description String
  debitAccount String   // chart of accounts code
  creditAccount String
  amount      Float    // cents as float (use BigInt in production)
  currency    String   @default("USD")
  sourceType  String   // "invoice" | "payment" | "po" | "expense" | "payroll"
  sourceId    String   // ID of the originating record
  createdById String
  createdAt   DateTime @default(now())
  
  @@index([orgId, entryDate])
  @@index([sourceType, sourceId])
}

model VendorInvoice {
  id              String   @id @default(cuid())
  orgId           String
  vendorId        String
  vendor         Vendor   @relation(fields: [vendorId], references: [id])
  poId            String?  // FK → PurchaseOrder (for 3-way match)
  po              PurchaseOrder? @relation(fields: [poId], references: [id])
  invoiceNumber  String
  invoiceDate    DateTime
  dueDate        DateTime
  amount        Float
  currency      String   @default("USD")
  status        String   @default("pending") // pending → matched → approved → paid | disputed
  matchStatus   String?  // "matched" | "quantity_mismatch" | "price_mismatch"
  paidAt        DateTime?
  stripePaymentId String?
  glEntryId     String?  // FK → GeneralLedger
  createdAt    DateTime @default(now())
  
  @@index([orgId, status])
  @@index([vendorId])
}

// --- GOODS RECEIPT (for 3-way match) ---
model GoodsReceipt {
  id          String   @id @default(cuid())
  orgId       String
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id])
  receiptDate DateTime
  status     String   @default("received")
  createdAt  DateTime @default(now())
}
