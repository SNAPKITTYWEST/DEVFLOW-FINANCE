generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id          String   @id @default(uuid())
  name        String
  domain     String?
  industry   String?
  website    String?
  settings   Json?
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  users      CompanyUser[]
  contracts  Contract[]
  invoices  Invoice[]
  payments  Payment[]
  vendors   Vendor[]
  purchaseOrders PurchaseOrder[]
  receipts  Receipt[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("user")
  avatar       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  companyUsers CompanyUser[]
  activities  ActivityLog[]
}

model CompanyUser {
  id        String   @id @default(uuid())
  companyId String
  userId   String
  role    String   @default("member")
  status   String   @default("active")
  createdAt DateTime @default(now())
  
  company  Company @relation(fields: [companyId], references: [id])
  user    User   @relation(fields: [userId], references: [id])
  
  @@unique([companyId, userId])
}

enum Permission {
  ADMIN
  MANAGER
  MEMBER
  VIEW_ONLY
}

model Entity {
  id        String   @id @default(uuid())
  companyId String?
  name      String
  type      String
  balance   BigInt   @default(0)
  vault     BigInt   @default(0)
  currency  String   @default("USD")
  parentLedger String?
  lastSync  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  company   Company? @relation(fields: [companyId], references: [id])
}

model Contract {
  id          String   @id @default(uuid())
  companyId  String
  customerId String?
  customerName String
  value      BigInt
  status     String   @default("draft")
  startDate DateTime?
  endDate   DateTime?
  terms     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  company   Company    @relation(fields: [companyId], references: [id])
  invoices Invoice[]
  performanceObligations PerformanceObligation[]
}

model PerformanceObligation {
  id          String   @id @default(uuid())
  contractId String
  name      String
  weight    Int      @default(0)
  allocated BigInt   @default(0n)
  status    String   @default("pending")
  createdAt DateTime @default(now())
  
  contract Contract   @relation(fields: [contractId], references: [id])
}

model Invoice {
  id          String   @id @default(uuid())
  companyId  String
  contractId String?
  invoiceNumber String
  customerId String?
  customerName String
  amount    BigInt
  taxAmount BigInt    @default(0n)
  status    String   @default("draft")
  dueDate   DateTime?
  issuedAt  DateTime @default(now())
  paidAt   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  company  Company   @relation(fields: [companyId], references: [id])
  contract Contract? @relation(fields: [contractId], references: [id])
  payments Payment[]
}

model Payment {
  id          String   @id @default(uuid())
  companyId  String
  invoiceId String?
  amount   BigInt
  method   String   @default("card")
  reference String?
  status   String   @default("pending")
  receivedAt DateTime?
  createdAt DateTime @default(now())
  
  company Company  @relation(fields: [companyId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])
}

model Vendor {
  id          String   @id @default(uuid())
  companyId  String
  name      String
  email    String?
  phone    String?
  address  String?
  taxId    String?
  status   String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  company       Company         @relation(fields: [companyId], references: [id])
  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id          String   @id @default(uuid())
  companyId  String
  vendorId  String
  poNumber  String
  amount   BigInt
  status   String   @default("draft")
  dueDate  DateTime?
  approvedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  company  Company  @relation(fields: [companyId], references: [id])
  vendor   Vendor   @relation(fields: [vendorId], references: [id])
  receipts Receipt[]
}

model Receipt {
  id          String   @id @default(uuid())
  companyId  String
  purchaseOrderId String
  amount   BigInt
  matchedAmount BigInt    @default(0n)
  status   String   @default("pending")
  matchedAt DateTime?
  createdAt DateTime @default(now())
  
  company       Company        @relation(fields: [companyId], references: [id])
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
}

model QuickBooksConnection {
  id           String   @id @default(uuid())
  companyId   String
  realmId    String
  accessToken String
  refreshToken String
  expiresAt  DateTime
  status    String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  company Company @relation(fields: [companyId], references: [id])
}

model Contact {
  id        String   @id @default(uuid())
  name     String
  email    String?
  phone    String?
  company  String?
  status   String   @default("lead")
  source   String?
  notes    String?
  metadata Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id        String   @id @default(uuid())
  name      String
  email    String?
  phone    String?
  company  String?
  source   String?
  status   String   @default("new")
  score    Int      @default(50)
  converted Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id        String   @id @default(uuid())
  name     String
  type     String?
  domain   String?
  industry String?
  website  String?
  metadata Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Interaction {
  id         String   @id @default(uuid())
  type       String
  subject    String?
  content   String
  metadata  Json?
  contactId String?
  leadId    String?
  userId    String?
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  event     String
  message   String
  metadata  Json?
  timestamp DateTime @default(now())
  userId    String?
  
  user     User?    @relation(fields: [userId], references: [id])
}

model BankConnection {
  id           String   @id @default(uuid())
  accessToken  String
  itemId       String
  institution  String
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Integration {
  id        String   @id @default(uuid())
  provider  String
  config   Json
  status   String   @default("connected")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}