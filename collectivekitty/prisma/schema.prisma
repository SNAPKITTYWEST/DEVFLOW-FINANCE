// SnapKitty Collective | Prisma Schema v5.0.0
// BIFROST SOVEREIGN CORE: Fintech, Ledger, & Immutable Audit Chains

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// CORE ENTITIES
// ============================================================================

model User {
  id          String   @id @default(cuid())
  azureOid    String   @unique
  email       String   @unique
  name        String?
  role        String   @default("user")
  orgId       String?
  organization Organization? @relation(fields: [orgId], references: [id])
  createdAt   DateTime @default(now())
  opportunities Opportunity[]
  purchaseRequisitions PurchaseRequisition[]
}

model Organization {
  id                    String   @id @default(cuid())
  name                  String
  stripeAccountId       String?
  createdAt             DateTime @default(now())
  users                User[]
  opportunities        Opportunity[]
  vendorInvoices       VendorInvoice[]
  financialAccounts    FinancialAccount[]
  ledgerEntries        LedgerEntry[]
}

model Company {
  id          String   @id @default(cuid())
  companyId    String   @unique
  name        String
  domain      String?
  industry   String?
  createdAt   DateTime @default(now())
  opportunities Opportunity[]
}

model Opportunity {
  id          String   @id @default(cuid())
  oppId       String   @unique
  name        String
  value       Float
  stage       String   @default("prospecting")
  companyId   String
  company    Company  @relation(fields: [companyId], references: [id])
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project?

  @@index([ownerId])
  @@index([stage])
}

// ============================================================================
// PROCUREMENT & AP
// ============================================================================

model Vendor {
  id          String   @id @default(cuid())
  externalId  String   @unique
  name        String
  category    String
  riskScore   Int      @default(0)
  createdAt   DateTime @default(now())
  purchaseOrders PurchaseOrder[]
  purchaseRequisitions PurchaseRequisition[]
  vendorInvoices VendorInvoice[]
}

model PurchaseRequisition {
  id            String   @id @default(cuid())
  title         String
  description   String?
  totalAmount  Float
  status      String   @default("pending")
  requesterId  String
  requester   User     @relation(fields: [requesterId], references: [id])
  approverId  String?
  approvedAt DateTime?
  createdAt  DateTime @default(now())
  items       PurchaseRequisitionItem[]
  orders      PurchaseOrder[]
}

model PurchaseRequisitionItem {
  id            String   @id @default(cuid())
  description   String
  quantity     Int
  unitPrice    Float
  totalPrice  Float
  requisitionId String
  requisition PurchaseRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
}

model PurchaseOrder {
  id            String   @id @default(cuid())
  requisitionId String?
  requisition PurchaseRequisition? @relation(fields: [requisitionId], references: [id])
  vendorId    String
  vendor     Vendor  @relation(fields: [vendorId], references: [id])
  title      String
  totalAmount Float
  status     String   @default("pending")
  createdAt  DateTime @default(now())
}

model VendorInvoice {
  id              String   @id @default(cuid())
  orgId           String
  organization    Organization @relation(fields: [orgId], references: [id])
  vendorId        String
  vendor         Vendor  @relation(fields: [vendorId], references: [id])
  poId            String?
  po              PurchaseOrder? @relation(fields: [poId], references: [id])
  invoiceNumber  String
  invoiceDate    DateTime
  dueDate        DateTime
  amount        Float
  currency      String   @default("USD")
  status        String   @default("pending") // pending | paid | overdue
  paidAt        DateTime?
  createdAt    DateTime @default(now())
}

// ============================================================================
// BIFROST FINANCIAL CORE (Immutable Ledger)
// ============================================================================

model FinancialAccount {
  id                String          @id @default(cuid())
  orgId             String
  organization      Organization    @relation(fields: [orgId], references: [id])
  accountName       String
  accountType       String          // operating | reserve | payroll
  currency          String          @default("USD")
  provider          String          // unit | stripe | plaid
  currentBalance    Float           @default(0)
  availableBalance  Float           @default(0)
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  transactions      FinancialTransaction[]
}

model FinancialTransaction {
  id                String          @id @default(cuid())
  orgId             String
  accountId         String
  account           FinancialAccount @relation(fields: [accountId], references: [id])
  externalId        String?         @unique
  type              String          // credit | debit
  amount            Float
  description       String
  glCode            String?
  status            String          // pending | posted | failed
  reconciliationId  String?
  postedAt          DateTime?
  createdAt         DateTime        @default(now())
}

model LedgerEntry {
  id                String          @id @default(cuid())
  orgId             String
  organization      Organization    @relation(fields: [orgId], references: [id])
  entryNumber       String          @unique  // LE-2024-0001
  entryDate         DateTime
  description       String
  hash              String          // SHA-256 for tamper detection
  previousHash      String?         // Chain link
  lines             LedgerLine[]
  createdAt         DateTime        @default(now())
}

model LedgerLine {
  id                String       @id @default(cuid())
  entryId           String
  entry             LedgerEntry  @relation(fields: [entryId], references: [id])
  accountCode       String
  debit             Float        @default(0)
  credit            Float        @default(0)
  description       String?
  transactionId     String?
}

// ============================================================================
// FINTECH BaaS (Cards)
// ============================================================================

model VirtualCard {
  id                String       @id @default(cuid())
  orgId             String
  userId            String
  unitCardId        String       @unique
  last4             String
  expiryMonth       Int
  expiryYear        Int
  status            String       @default("active")
  spendLimit        Float?
  spentToDate       Float        @default(0)
  createdAt         DateTime     @default(now())
  transactions      CardTransaction[]
}

model CardTransaction {
  id                String      @id @default(cuid())
  cardId            String
  card              VirtualCard @relation(fields: [cardId], references: [id])
  unitTransactionId String      @unique
  merchant          String
  amount            Float
  status            String
  createdAt         DateTime    @default(now())
}

// ============================================================================
// ERP / PROJECT MATERIALIZATION
// ============================================================================

model Project {
  id            String   @id @default(cuid())
  orgId         String
  name          String
  status        String   @default("active")
  budget        Float
  opportunityId String?  @unique
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  createdAt     DateTime @default(now())
  tasks         ProjectTask[]
}

model ProjectTask {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  title       String
  status      String   @default("todo")
  createdAt   DateTime @default(now())
}

// ============================================================================
// SYSTEM EVENTS
// ============================================================================

model Event {
  id        String   @id @default(cuid())
  type      String
  payload   Json?
  timestamp DateTime @default(now())
}
